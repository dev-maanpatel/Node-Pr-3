<%- include("../partials/head", { title }) %>
<%- include("../partials/header") %>

<section class="contact-section">

        <div class="container">

            <div class="contact-wrapper">

                <div class="contact-left">

                    <span class="contact-tag">Contact</span>

                    <h1>Get in touch with us</h1>

                    <p>
                        Leverage agile frameworks to provide a robust synopsis for strategy
                        foster collaborative thinking to further the overall value.
                    </p>

                    <div class="contact-info">

                        <div class="info-box">
                            <div class="icon">
                                <img src="/assest/img/icon-1.png" alt="">
                            </div>

                            <div class="info-text">
                                <h4>Email</h4>
                                <span>contact@logistics.com</span>
                            </div>
                        </div>

                        <div class="info-box">
                            <div class="icon">
                                <img src="/assest/img/icon-2.png" alt="">
                            </div>

                            <div class="info-text">
                                <h4>Call Us</h4>
                                <span>(00) 112 365 489</span>
                            </div>
                        </div>

                        <div class="info-box">
                            <div class="icon">
                                <img src="/assest/img/icon.png" alt="">
                            </div>

                            <div class="info-text">
                                <h4>Mon - Sat 9.00 - 18.00</h4>
                                <span>Sunday Closed</span>
                            </div>
                        </div>

                    </div>

                </div>

                <div class="contact-right">

                    <form>

                        <div class="form-row">

                            <div class="input-group">
                                <input type="text" placeholder="Your name*">
                            </div>

                            <div class="input-group">
                                <input type="email" placeholder="Email*">
                            </div>

                        </div>

                        <div class="form-row">

                            <div class="input-group">
                                <input type="text" placeholder="Phone Number*">
                            </div>

                            <div class="input-group">
                                <input type="text" placeholder="City*">
                            </div>

                        </div>

                        <div class="input-group">
                            <textarea placeholder="Your Message"></textarea>
                        </div>

                        <button type="submit" class="submit-btn">
                            Submit Message
                        </button>

                    </form>

                </div>

            </div>

            <div class="brand-images">

                <img src="/assest/img/gallery-1.png" alt="">

                <img src="/assest/img/gallery-2.png" alt="">

                <img src="/assest/img/gallery-3.png" alt="">

                <img src="/assest/img/gallery-4.png" alt="">

            </div>

        </div>

    </section>

<%- include("../partials/footer") %>
