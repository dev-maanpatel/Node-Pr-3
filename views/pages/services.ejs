<%- include("../partials/head", { title }) %>
<%- include("../partials/header") %>

<section class="services-section container">

        <div class="left-content">
            <span>What We Do</span>

            <h2>
                Safe & Reliable
                Cargo Solutions
            </h2>
        </div>

        <div class="services-grid">

            <div class="service-box">
                <div class="service-icon">
                    <i class="ri-ship-line"></i>
                </div>

                <div class="service-text">
                    <h3>Sea Transport Services</h3>

                    <p>
                        Wherever your cargo is going, we
                        can arrange the shipment for you
                        and remain competitive with the
                        business market.
                    </p>
                </div>
            </div>

            <div class="service-box">
                <div class="service-icon">
                    <i class="ri-store-2-line"></i>
                </div>

                <div class="service-text">
                    <h3>Warehousing Services</h3>

                    <p>
                        We have buildings that can provide
                        you with distribution, storage,
                        inventory management, order
                        fulfilment services.
                    </p>
                </div>
            </div>

            <div class="service-box">
                <div class="service-icon">
                    <i class="ri-plane-line"></i>
                </div>

                <div class="service-text">
                    <h3>Air Freight Services</h3>

                    <p>
                        We're partners with airlines and
                        freight forwarders to offer seamless
                        air freight solutions to the clients all
                        over the world.
                    </p>
                </div>
            </div>

            <div class="service-box">
                <div class="service-icon">
                    <i class="ri-truck-line"></i>
                </div>

                <div class="service-text">
                    <h3>Local Shipping Services</h3>

                    <p>
                        We work close with strategic
                        partners to ensure our domestic
                        trucking offers clients everything
                        they need in their place.
                    </p>
                </div>
            </div>

        </div>

    </section>

<%- include("../partials/footer") %>
